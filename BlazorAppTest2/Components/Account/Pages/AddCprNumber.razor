@page "/Account/AddCprNumber"
@using System.ComponentModel.DataAnnotations
@using BlazorAppTest2.Data;
@using Microsoft.AspNetCore.Identity;

@inject AuthenticationStateProvider _authenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<h3>Add CPR Number</h3>
<div class="row">
    <div class="col-lg-6">
        <section>
            <StatusMessage Message="@errorMessage" />
            <EditForm EditContext="editContext" method="post" OnSubmit="SaveCprNumber" FormName="AddCprNumber">
                <DataAnnotationsValidator />
                <h2>Enter your CPR Number</h2>
                <hr />
                <ValidationSummary class="text-danger" role="alert" />
                <div class="form-floating mb-3">
                    <InputText @bind-Value="Input.CprNumber" id="Input.CprNumber" class="form-control" autocomplete="username webauthn" aria-required="true" placeholder="111111-1111" />
                    <label for="Input.CprNumber" class="form-label">Cpr Number</label>
                    <ValidationMessage For="() => Input.CprNumber" class="text-danger" />
                </div>

                <div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary">Submit</button>
                </div>
            </EditForm>
        </section>
    </div>
</div>


@code {
    private string? errorMessage;
    private EditContext editContext = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private async Task SaveCprNumber()
    {
        var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        byte[] hashedCprAsByteArray = System.Security.Cryptography.Rfc2898DeriveBytes.Pbkdf2(
            Input.CprNumber, 
            System.Text.Encoding.UTF8.GetBytes("230271"), 
            10, 
            System.Security.Cryptography.HashAlgorithmName.SHA256, 
            32
        );

        string hashedCpr = Convert.ToBase64String(hashedCprAsByteArray);

        bool validationPass = true;

        if(user.CprNumber == null)
        {
            user.CprNumber = hashedCpr;
            await UserManager.UpdateAsync(user);
        }
        else
        {
            validationPass = user.CprNumber == hashedCpr;
        }
        if (validationPass)
        {
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else
        {
            errorMessage = "Error: Invalid CPR";
        }
    }
    protected override async Task OnInitializedAsync()
    {
        Input ??= new();
        editContext = new EditContext(Input);
    }
    private sealed class InputModel
    {
        [Required]
        public string CprNumber { get; set; } = "";
    }
}
